<!-- Variable -->
<input value="@name" />

<!-- Method -->
<input value="@GetName()" />

<!-- Partial: Combine with static text -->
<input value="@name C#" />
<input value="@(name)s" />

@code {
    private string name = "Blazor";

    private string GetName() => $"Name: {name}";
}
